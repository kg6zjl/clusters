{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "prConcurrentLimit": 1,
  "enabledManagers": ["helmfile", "helm-values", "flux", "kubernetes"],
  "flux": {
    "fileMatch": ["home-cluster/[^/]+/helmrelease\\.yaml$"]
  },
  "constraints": {
    "helm": "^3.15.0"
  },
  "packageRules": [
    {
      "matchManagers": ["helmfile"],
      "constraints": {
        "helm": "^3.15.0"
      }
    }
  ]
}
